{
  "name": "aura-health-telehealth",
  "version": "1.0.0",
  "scripts": {
    "start": "node start.js",
    "build": "npm run install-backend && npm run install-frontend && npm run build-frontend",
    "install-backend": "npm install --prefix telehealth-backend",
    "install-frontend": "npm install --prefix frontend",
    "build-frontend": "cd frontend && npm run build"
  },
  "dependencies": {
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
